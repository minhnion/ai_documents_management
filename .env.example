# Application
APP_NAME="Guideline Management Platform API"
APP_VERSION="0.1.0"
APP_ENV="development"       # development | staging | production
DEBUG=true

# Server
HOST="0.0.0.0"
PORT=8000

# Database (self-managed by docker compose)
DB_HOST=localhost
DB_PORT=5436
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=guideline_management
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
LOCAL_STORAGE_ROOT=uploads
SCORE_THRESHOLD=0.65
CHUNK_MAX_CHARS=3000

# CORS – comma-separated list (use ["*"] for development)
ALLOWED_ORIGINS=["*"]

# Core AI service (configure when available)
CORE_AI_BASE_URL=
CORE_AI_API_KEY=
LANDINGAI_API_KEY=
LANDINGAI_API_URL="https://api.va.landing.ai/v1/ade/parse"
LANDINGAI_MODEL_NAME="dpt-2-latest"
LANDINGAI_USE_SDK=false
OPENAI_API_KEY=
OPENAI_API_URL="https://api.openai.com/v1"
OPENAI_MODEL_NAME="gpt-4.1"
OPENAI_EMBEDDING_MODEL_NAME="text-embedding-3-large"

# Auth / Security
JWT_SECRET_KEY="change-this-secret"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTO_CREATE_TABLES=true
SEED_AUTH_DATA=true
DEFAULT_ADMIN_EMAIL="admin@example.com"
DEFAULT_ADMIN_PASSWORD="ChangeMe123!"
DEFAULT_ADMIN_FULL_NAME="System Admin"
