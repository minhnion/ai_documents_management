# Application
APP_NAME="Guideline Management Platform API"
APP_VERSION="0.1.0"
APP_ENV="development"       # development | staging | production
DEBUG=true

# Server
HOST="0.0.0.0"
PORT=8000

# Database (PostgreSQL on Docker)
DB_HOST=localhost
# Optional: used by docker-compose backend container to reach DB on host
DB_HOST_DOCKER=host.docker.internal
DB_PORT=5436
DB_USER=phuongnh
DB_PASSWORD=1234
DB_NAME=chatbot_healthcare
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
LOCAL_STORAGE_ROOT=uploads

# CORS – comma-separated list (use ["*"] for development)
ALLOWED_ORIGINS=["*"]

# Core AI service (configure when available)
CORE_AI_BASE_URL=
CORE_AI_API_KEY=

# Auth / Security
JWT_SECRET_KEY="change-this-secret"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTO_CREATE_TABLES=true
SEED_AUTH_DATA=true
DEFAULT_ADMIN_EMAIL="admin@example.com"
DEFAULT_ADMIN_PASSWORD="ChangeMe123!"
DEFAULT_ADMIN_FULL_NAME="System Admin"
